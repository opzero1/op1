{
	"name": "@op1/workspace",
	"version": "0.5.1",
	"description": "Project-scoped plan management plugin for OpenCode - plans, notepads, verification hooks",
	"type": "module",
	"main": "dist/workspace.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/workspace.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "bun build src/index.ts --outfile dist/workspace.js --target bun --format esm --external zod --external node-notifier",
		"typecheck": "tsc --noEmit",
		"dev": "bun run build --watch"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@opencode-ai/plugin": "^1.0.0",
		"node-notifier": "^10.0.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.1.0",
		"@types/node-notifier": "^8.0.5",
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/op1/op1.git",
		"directory": "packages/workspace"
	},
	"license": "MIT",
	"keywords": [
		"opencode",
		"plugin",
		"plans",
		"workspace"
	]
}
