{
	"name": "@op1/reprompt",
	"version": "0.5.1",
	"description": "Optional reprompt plugin for bounded evidence packing and safe retry orchestration",
	"type": "module",
	"main": "dist/reprompt.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/reprompt.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "bun build src/index.ts --outfile dist/reprompt.js --target bun --format esm --external @opencode-ai/plugin --external zod",
		"typecheck": "tsc --noEmit",
		"dev": "bun run build --watch"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@opencode-ai/plugin": "^1.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.1.0",
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/op1/op1.git",
		"directory": "packages/reprompt"
	},
	"license": "MIT",
	"keywords": [
		"opencode",
		"plugin",
		"reprompt",
		"retry"
	]
}
