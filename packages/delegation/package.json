{
	"name": "@op1/delegation",
	"version": "0.1.0",
	"description": "Async task delegation plugin for OpenCode with background output, cancellation, and citation-friendly task records",
	"type": "module",
	"main": "dist/delegation.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/delegation.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "bun build src/index.ts --outfile dist/delegation.js --target bun --format esm --external @opencode-ai/plugin",
		"typecheck": "tsc --noEmit",
		"dev": "bun run build --watch"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@opencode-ai/plugin": "^1.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.1.0",
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/op1/op1.git",
		"directory": "packages/delegation"
	},
	"license": "MIT",
	"keywords": [
		"opencode",
		"plugin",
		"delegation",
		"task",
		"background"
	]
}
